{
  "name": "js_threvo-shop",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "concurrently \"npm run build:css\" \"npm run build:11ty\"",
    "build:css": "npx @tailwindcss/cli -i ./src/static/styles.css -o ./_site/static/styles.css",
    "build:11ty": "npx @11ty/eleventy",
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:11ty\"",
    "dev:css": "npx @tailwindcss/cli -i ./src/static/styles.css -o ./_site/static/styles.css --watch",
    "dev:11ty": "npx @11ty/eleventy --serve"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@11ty/eleventy": "^3.1.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2"
  }
}
